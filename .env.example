# # MongoDB - leave empty to use default: mongodb://localhost:27017/ai-clinic
# MONGO_URI=mongodb://localhost:27017/ai-clinic

# # JWT - generate random strings for production (e.g. node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# JWT_SECRET=your-jwt-secret-min-32-chars
# JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# PORT=5001
# CLIENT_ORIGIN=http://localhost:3000

# # Optional: Gemini API from https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# # Optional: Groq API from https://console.groq.com/keys
# GROQ_API_KEY=
